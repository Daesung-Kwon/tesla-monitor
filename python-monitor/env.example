# Telegram Bot 설정 (완전 무료!)
# @BotFather에게서 받은 Token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# 내 Chat ID (@userinfobot에게서 확인)
TELEGRAM_CHAT_ID=987654321

# 데이터 저장 디렉토리
DATA_DIR=./data

# ==========================================
# 키워드 필터링 설정 (선택 사항)
# ==========================================

# 키워드 필터 활성화 여부 (true/false)
# false: 모든 Tesla 뉴스 알림 (기본)
# true: 특정 키워드가 포함된 뉴스만 알림
KEYWORD_FILTER_ENABLED=false

# 필터링할 키워드 (쉼표로 구분, 영문/한글 모두 가능)
# 예시 프리셋:
#
# 1. Cybertruck 관심:
#   FILTER_KEYWORDS=cybertruck,cyber truck,사이버트럭
#
# 2. FSD/Autopilot 관심:
#   FILTER_KEYWORDS=fsd,full self-driving,autopilot,자율주행,오토파일럿
#
# 3. 가격/할인 관심:
#   FILTER_KEYWORDS=price,pricing,discount,sale,가격,할인,세일
#
# 4. 한국 관련:
#   FILTER_KEYWORDS=korea,korean,한국,seoul,서울,기가팩토리
#
# 5. 소프트웨어 업데이트:
#   FILTER_KEYWORDS=update,software,version,firmware,업데이트,펌웨어
#
# 6. 종합 (관심사 여러 개):
#   FILTER_KEYWORDS=cybertruck,fsd,price,korea,update,한국,가격
#
FILTER_KEYWORDS=

# ==========================================
# 기사 최신성 필터 (선택 사항)
# ==========================================

# 최근 N일 이내 기사만 처리 (기본: 3일)
# 첫 실행 시 오래된 기사가 알림으로 오는 것을 방지
#
# 권장 값:
# - 3: 최근 3일 이내 (추천, 기본값)
# - 7: 최근 1주일 이내
# - 1: 최근 1일 이내 (매우 최신만)
# - 14: 최근 2주일 이내
#
MAX_ARTICLE_AGE_DAYS=3
